import requests
import threading
import time
from datetime import datetime


class ConcurrentHTTPClient:
    def __init__(self, url='http://localhost:8080', num_clients=10):
        self.url = url
        self.num_clients = num_clients
        self.results = []
        self.lock = threading.Lock()

    def send_request(self, client_id):
        """Отправка одного запроса"""
        try:
            start_time = time.time()
            timestamp = datetime.now().strftime('%H:%M:%S.%f')[:-3]

            print(f"[{timestamp}] Клиент #{client_id:2d}: Отправка запроса...")

            response = requests.get(self.url, timeout=30)
            duration = time.time() - start_time

            with self.lock:
                self.results.append({
                    'id': client_id,
                    'status': response.status_code,
                    'duration': duration
                })

            print(f"[{timestamp}] Клиент #{client_id:2d}: ✓ Статус {response.status_code} (⏱️ {duration:.2f} сек)")

        except Exception as e:
            print(f"[!] Клиент #{client_id}: ✗ Ошибка - {e}")

    def run(self):
        """Запуск всех клиентов"""
        print(f"\n{'=' * 60}")
        print(f"🚀 Запуск HTTP клиентов")
        print(f"{'=' * 60}")
        print(f"📍 Сервер: {self.url}")
        print(f"👥 Клиентов: {self.num_clients}")
        print(f"{'=' * 60}\n")

        start_time = time.time()
        threads = []

        # Запускаем клиентов
        for i in range(self.num_clients):
            thread = threading.Thread(target=self.send_request, args=(i + 1,))
            thread.daemon = True
            threads.append(thread)
            thread.start()
            time.sleep(0.1)  # Небольшая задержка между запусками

        # Ждем завершения
        for thread in threads:
            thread.join()

        total_time = time.time() - start_time

        # Статистика
        print(f"\n{'=' * 60}")
        print(f"📊 Статистика")
        print(f"{'=' * 60}")
        successful = len([r for r in self.results if r['status'] == 200])
        print(f"✅ Успешно: {successful}/{self.num_clients}")

        if self.results:
            durations = [r['duration'] for r in self.results]
            print(f"⏱️  Среднее время: {sum(durations) / len(durations):.2f} сек")
            print(f"🐌 Минимум: {min(durations):.2f} сек")
            print(f"⚡ Максимум: {max(durations):.2f} сек")

        print(f"📦 Общее время: {total_time:.2f} сек")
        print(f"{'=' * 60}")


if __name__ == "__main__":
    import sys

    num_clients = 10
    if len(sys.argv) > 1:
        try:
            num_clients = int(sys.argv[1])
        except:
            pass

    client = ConcurrentHTTPClient(num_clients=num_clients)
    client.run()
